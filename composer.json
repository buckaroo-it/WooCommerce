{
    "name": "buckaroo/woocommerce",
    "description": "Buckaroo Woocommerce plugin",
    "type": "wordpress-plugin",
    "license": "CC-BY-NC-ND-3.0",
    "require": {
        "buckaroo/sdk": "^1.11"
    },
    "require-dev": {
        "phpunit/phpunit" : "7.5.20",
        "squizlabs/php_codesniffer": "3.*",
        "wp-coding-standards/wpcs": "^2.3",
        "woocommerce/woocommerce-sniffs": "^0.1",
        "pheromone/phpcs-security-audit":"*",
        "phpcompatibility/phpcompatibility-wp": "*",
        "object-calisthenics/phpcs-calisthenics-rules": "^3.7",
        "yoast/phpunit-polyfills": "^1.0",
        "phpro/grumphp": "^1.13"
    },
    "authors": [
        {
            "name": "Buckaroo",
            "email": "support@buckaroo.nl",
            "homepage": "https://www.buckaroo.nl"
        }
    ],
    "support": {
        "email": "support@buckaroo.nl",
        "issues": "https://docs.buckaroo.io/docs/en/contact-us"
    },
    "homepage": "https://www.buckaroo.nl",
    "version" : "3.11.0",
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpro/grumphp": false
        }
    },
    "autoload": {
        "psr-4": {
            "WC_Buckaroo\\Dependencies\\": "dist/dependencies/"
        },
        "classmap": ["dist/classes/dependencies"]
    },
    "extra": {
        "mozart": {
            "dep_namespace": "WC_Buckaroo\\Dependencies\\",
            "dep_directory": "/dist/dependencies/",
            "classmap_directory": "/dist/classes/dependencies/",
            "classmap_prefix": "WC_Buckaroo_"
        }
    }
}
